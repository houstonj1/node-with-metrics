{
  "name": "node-with-metrics",
  "version": "1.11.1",
  "description": "Node with Metrics",
  "exports": "./dist/index.js",
  "repository": "https://github.com/houstonj1/node-with-metrics",
  "author": "James Houston <james@houston.dev>",
  "license": "MIT",
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "nodemon --exec node --no-warnings=ExperimentalWarning --import ./src/tracing.ts --loader ts-node/esm src/index.ts",
    "lint": "eslint src/**/*.ts --fix && prettier --write .",
    "lint:ci": "eslint src/**/*.ts --fix && prettier --check .",
    "start": "node --import ./dist/tracing.js dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "express": "^5.2.1",
    "prom-client": "^15.1.3"
  },
  "resolutions": {
    "tar": "7.5.13",
    "minimatch": "9.0.9",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
