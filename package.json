{
  "name": "node-with-metrics",
  "version": "1.11.4",
  "description": "Node with Metrics",
  "exports": "./dist/index.js",
  "repository": "https://github.com/houstonj1/node-with-metrics",
  "author": "James Houston <james@houston.dev>",
  "license": "MIT",
  "packageManager": "yarn@4.14.1",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "nodemon --exec node --no-warnings=ExperimentalWarning --import ./src/tracing.ts --loader ts-node/esm src/index.ts",
    "lint": "eslint src/**/*.ts --fix && prettier --write .",
    "lint:ci": "eslint src/**/*.ts --fix && prettier --check .",
    "start": "node --import ./dist/tracing.js dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "express": "^5.2.1",
    "prom-client": "^15.1.3"
  },
  "resolutions": {
    "tar": "7.5.16",
    "@opentelemetry/core": "2.8.0",
    "js-yaml@npm:^3.13.1": "4.2.0",
    "test-exclude@npm:^6.0.0": "7.0.1",
    "glob": "13.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
