{
  "name": "node-with-metrics",
  "version": "1.10.1",
  "description": "Node with Metrics",
  "exports": "./dist/index.js",
  "repository": "https://github.com/houstonj1/node-with-metrics",
  "author": "James Houston <james@houston.dev>",
  "license": "MIT",
  "packageManager": "yarn@4.13.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "nodemon --exec node --no-warnings=ExperimentalWarning --loader ts-node/esm src/index.ts",
    "lint": "eslint src/**/*.ts --fix && prettier --write .",
    "lint:ci": "eslint src/**/*.ts --fix && prettier --check .",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "express": "^5.2.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
